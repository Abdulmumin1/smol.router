{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "tiny-router-docs",
  "compatibility_date": "2026-06-20",
  "routes": [
    {
      "pattern": "router.ai-query.dev",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
